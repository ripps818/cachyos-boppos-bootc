#!/bin/bash
set -e

# Colors for output
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

run_cmd() {
    if [ "$VERBOSE" = true ]; then
        "$@"
    else
        "$@" > /dev/null
    fi
}

update_os() {
    if [ "$AUTO_YES" = true ]; then
        echo -e "${GREEN}==> Auto-yes enabled. Skipping package diff...${NC}"
    else
        echo -e "${GREEN}==> Checking for OS package changes...${NC}"
        
        local diff_cmd=""
        if command -v bopp-diff &> /dev/null; then
            diff_cmd="bopp-diff"
        elif command -v bopp-diff.sh &> /dev/null; then
            diff_cmd="bopp-diff.sh"
        fi

        if [ -n "$diff_cmd" ]; then
            sudo "$diff_cmd" || echo -e "${BLUE}Warning: Failed to calculate update diff.${NC}"
            echo -ne "\n${BLUE}Proceed with the OS update? [Y/n]${NC} "
            read -r response
            if [[ "$response" =~ ^([nN][oO]|[nN])$ ]]; then
                echo "OS update cancelled."
                return
            fi
        fi
    fi

    echo -e "\n${GREEN}==> Updating OS image (bootc)...${NC}"
    run_cmd sudo bootc upgrade
}

update_fw() {
    echo -e "\n${GREEN}==> Checking for firmware updates (fwupd)...${NC}"
    if command -v fwupdmgr &> /dev/null; then
        run_cmd sudo fwupdmgr refresh || true
        run_cmd sudo fwupdmgr update -y || true
    else
        echo "fwupdmgr not found, skipping firmware updates."
    fi
    # Clean up stale temporary caches to prevent revokefs-fuse glib crashes
    sudo rm -rf /var/tmp/flatpak-cache-* 2>/dev/null || true
}

update_flatpak() {
    echo -e "\n${GREEN}==> Updating Flatpaks...${NC}"
    if command -v flatpak &> /dev/null; then
        run_cmd flatpak update -y || {
            echo -e "${BLUE}Warning: flatpak update encountered an error (likely a known FUSE bug). Run 'flatpak repair' if the issue persists.${NC}"
        }
    else
        echo "flatpak not found, skipping."
    fi
}

update_brew() {
    echo -e "\n${GREEN}==> Updating Homebrew...${NC}"
    if command -v brew &> /dev/null; then
        run_cmd brew update
        run_cmd brew upgrade
    else
        echo "Homebrew not found, skipping."
    fi
}

update_distrobox() {
    echo -e "\n${GREEN}==> Updating Distroboxes...${NC}"
    if command -v distrobox &> /dev/null; then
        run_cmd distrobox upgrade --all || true
    else
        echo "distrobox not found, skipping."
    fi
}

show_help() {
    echo "Usage: boppos-update [OPTIONS]"
    echo "Options:"
    echo "  -o, --os         Update OS image (bootc)"
    echo "  -w, --fw         Update firmware (fwupdmgr)"
    echo "  -f, --flatpak    Update Flatpaks"
    echo "  -b, --brew       Update Homebrew"
    echo "  -d, --distrobox  Update all Distroboxes"
    echo "  -v, --verbose    Show full output for package managers"
    echo "  -a, --all        Run default updates (OS, FW, Flatpak, Brew)"
    echo "                   Note: Distrobox updates must be called explicitly."
    echo "  -y, --yes        Auto-confirm updates and skip interactive prompts (e.g. diffs)"
    echo "  -F, --force      Alias for --yes"
    echo "  -h, --help       Show this help message"
}

# Parse arguments
RUN_OS=false
RUN_FW=false
RUN_FLATPAK=false
RUN_BREW=false
RUN_DISTROBOX=false
AUTO_YES=false
VERBOSE=false

if [ "$#" -eq 0 ]; then
    RUN_OS=true; RUN_FW=true; RUN_FLATPAK=true; RUN_BREW=true
else
    while [[ "$#" -gt 0 ]]; do
        case $1 in
            --os) RUN_OS=true ;;
            --fw) RUN_FW=true ;;
            --flatpak) RUN_FLATPAK=true ;;
            --brew) RUN_BREW=true ;;
            --distrobox) RUN_DISTROBOX=true ;;
            --all) RUN_OS=true; RUN_FW=true; RUN_FLATPAK=true; RUN_BREW=true ;;
            --yes|-y|--force|-F) AUTO_YES=true ;;
            --verbose|-v) VERBOSE=true ;;
            --help) show_help; exit 0 ;;
            -[!-]* ) # Match short flags (a single dash followed by non-dash characters)
                flags="${1#-}"
                for (( i=0; i<${#flags}; i++ )); do
                    case "${flags:$i:1}" in
                        o) RUN_OS=true ;;
                        w) RUN_FW=true ;;
                        f) RUN_FLATPAK=true ;;
                        b) RUN_BREW=true ;;
                        d) RUN_DISTROBOX=true ;;
                        a) RUN_OS=true; RUN_FW=true; RUN_FLATPAK=true; RUN_BREW=true ;;
                        y|F) AUTO_YES=true ;;
                        v) VERBOSE=true ;;
                        h) show_help; exit 0 ;;
                        *) echo "Unknown parameter passed: -${flags:$i:1}"; show_help; exit 1 ;;
                    esac
                done
                ;;
            *) echo "Unknown parameter passed: $1"; show_help; exit 1 ;;
        esac
        shift
    done
fi

echo -e "${BLUE}Starting CachyOS BoppOS System Update...${NC}\n"

# Pre-authenticate sudo if OS or Firmware is being updated
if [ "$RUN_OS" = true ] || [ "$RUN_FW" = true ]; then
    sudo -v
fi

[ "$RUN_OS" = true ] && update_os
[ "$RUN_FW" = true ] && update_fw
[ "$RUN_FLATPAK" = true ] && update_flatpak
[ "$RUN_BREW" = true ] && update_brew
[ "$RUN_DISTROBOX" = true ] && update_distrobox

echo -e "\n${BLUE}CachyOS BoppOS update complete!${NC}"
if [ "$RUN_OS" = true ]; then
    echo -e "\nNote: If the OS was updated via bootc, please reboot to apply the changes."
fi