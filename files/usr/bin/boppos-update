#!/bin/bash
set -e

# Colors for output
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo -e "${BLUE}Starting CachyOS BoppOS System Update...${NC}\n"

# 1. Update bootc deployment (OS update)
echo -e "${GREEN}==> Updating OS image (bootc)...${NC}"
sudo bootc upgrade

# 2. Firmware updates
echo -e "\n${GREEN}==> Checking for firmware updates (fwupd)...${NC}"
if command -v fwupdmgr &> /dev/null; then
    sudo fwupdmgr refresh || true
    # Using || true so a lack of updates doesn't fail the script
    sudo fwupdmgr update -y || true
else
    echo "fwupdmgr not found, skipping firmware updates."
fi

# 3. Flatpak updates
echo -e "\n${GREEN}==> Updating Flatpaks...${NC}"
if command -v flatpak &> /dev/null; then
    # Clean up stale temporary caches to prevent revokefs-fuse glib crashes
    sudo rm -rf /var/tmp/flatpak-cache-* 2>/dev/null || true

    # Update flatpaks. Using || prevents upstream flatpak crashes from halting the script.
    flatpak update -y || {
        echo -e "${BLUE}Warning: flatpak update encountered an error (likely a known FUSE bug). Run 'flatpak repair' if the issue persists.${NC}"
    }
else
    echo "flatpak not found, skipping."
fi

# 4. Homebrew updates (if installed)
echo -e "\n${GREEN}==> Updating Homebrew...${NC}"
if command -v brew &> /dev/null; then
    brew update && brew upgrade
else
    echo "Homebrew not found, skipping."
fi

echo -e "\n${BLUE}CachyOS BoppOS update complete!${NC}"
echo "Note: If the OS was updated via bootc, please reboot to apply the changes."